# Copy this to .env and fill in your API keys.

# Required for transcription
ASSEMBLYAI_API_KEY=your_assemblyai_key_here

# Required for AI summaries
GEMINI_API_KEY=your_gemini_key_here

# Optional overrides
# GEMINI_MODEL=gemini-2.0-flash-exp
# ASSEMBLYAI_MODEL=universal-3-pro

# Concurrency (tune for your API tier)
# MAX_TRANSCRIPTION_CONCURRENT=200   # AssemblyAI paid: 200, free: 5
# MAX_SUMMARIZATION_CONCURRENT=100   # Gemini Tier 1: 100, free: 5
# ASSEMBLYAI_POLLING_INTERVAL=15     # seconds between status checks
