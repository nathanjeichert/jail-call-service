# Copy this to .env for local-only processing.

# Optional local summarization overrides
# GEMMA_MODEL=unsloth/gemma-4-E2B-it-UD-MLX-4bit
# GEMMA_MAX_TOKENS=1024

# Concurrency for local models on Apple Silicon
# MAX_PARAKEET_CONCURRENT=1
# MAX_GEMMA_CONCURRENT=1

# Optional local binary override
# FLUIDAUDIO_PATH=/absolute/path/to/fluidaudiocli
